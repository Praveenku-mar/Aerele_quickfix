 "query": "SELECT \n    name AS \"Job Card:Link/Job Card:150\",\n    customer_name AS \"Customer:Data:200\",\n    device_type AS \"Device Type:Link/Device Type:200\",\n    status AS \"Status:Data:150\",\n    assigned_technician AS \"Technician:Link/Technician:150\",\n    estimated_cost AS \"Estimated Cost:Currency:120\",\n    creation AS \"Created On:Datetime:180\"\nFROM \n    `tabJob Card`\nWHERE\n    status = %(status)s AND device_type = %(device_type)s\nORDER BY\n    creation DESC",
